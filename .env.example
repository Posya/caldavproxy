# Upstream (authenticated) CalDAV server.
CALDAV_REMOTE_URL=https://caldav.example.com
CALDAV_USERNAME=user
CALDAV_PASSWORD=secret

# Optional: point directly at a calendar collection to skip auto-discovery.
# CALDAV_CALENDAR_PATH=/dav/calendars/user/personal/

# Secret path segment that hides the public feed.
# Feed is served at /<CALDAV_SECRET_PATH>/calendar.ics
# Generate one, e.g.: openssl rand -hex 16
CALDAV_SECRET_PATH=change-me-7f3a9c2b

# Public HTTP bind address.
LISTEN_ADDR=:8080

# How often to re-read the upstream calendar.
POLL_INTERVAL=15m

# Time window for the CalDAV query (some servers reject open-ended queries).
QUERY_WINDOW_PAST=720h
QUERY_WINDOW_FUTURE=8760h

# Log level: debug | info | warn | error. Logs are written to stdout.
# debug also adds source locations and request paths.
LOG_LEVEL=info
